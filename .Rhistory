library(ggpmisc)
library(arrow)
library(lubridate)
library(rstatix)
library(GGally)
library(ggplot2)
ggpairs(pairs_data,
lower = list(continuous = wrap("smooth", method = "lm")), # Add linear regression line to lower panels
upper = list(continuous = wrap("cor", method = "pearson")), # Add correlation coefficients to upper panels
diag = list(continuous = wrap("densityDiag")) # Add density plots to the diagonal
)
pairs_data <- so4_cl_data_L2temp %>%
select(SO4_mM, GW_salinity, Soil_EC, Soil_VWC, Soil_Salinity, Water_level)
ggpairs(pairs_data,
lower = list(continuous = wrap("smooth", method = "lm")), # Add linear regression line to lower panels
upper = list(continuous = wrap("cor", method = "pearson")), # Add correlation coefficients to upper panels
diag = list(continuous = wrap("densityDiag")) # Add density plots to the diagonal
)
pairs_long <- pairs_data %>%
pivot_longer(cols = -SO4_mM, names_to = "variable", values_to = "value")
View(pairs_long)
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
facet_wrap(~ variable, scales = "free_x") +
labs(title = "Sepal.Length against other variables",
y = "Sepal.Length",
x = "Value") +
theme_bw()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
facet_wrap(~ variable, scales = "free_x") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_bw()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
facet_wrap(~ variable, scales = "free_x", ncol = 1) +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_bw()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
facet_wrap(~ variable, scales = "free_x") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_bw()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
facet_wrap(~ variable, scales = "free") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_bw()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
facet_wrap(~ variable, scales = "free") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
# Adds the equation (y = mx + b)
stat_regline_equation(label.y = 8, aes(label = ..eq.label..)) +
# Adds the p-value and R^2
stat_cor(label.y = 7.5, aes(label = paste(..rr.label.., ..p.label.., sep = "~`,`~"))) +
facet_wrap(~ variable, scales = "free") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
# Adds the equation (y = mx + b)
stat_regline_equation(label.y = 60, aes(label = ..eq.label..)) +
# Adds the p-value and R^2
stat_cor(label.y = 50, aes(label = paste(..rr.label.., ..p.label.., sep = "~`,`~"))) +
facet_wrap(~ variable, scales = "free") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm", nrow = 1) +
# Adds the equation (y = mx + b)
stat_regline_equation(label.y = 60, aes(label = ..eq.label..)) +
# Adds the p-value and R^2
stat_cor(label.y = 50, aes(label = paste(..rr.label.., ..p.label.., sep = "~`,`~"))) +
facet_wrap(~ variable, scales = "free") +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
# Adds the equation (y = mx + b)
stat_regline_equation(label.y = 60, aes(label = ..eq.label..)) +
# Adds the p-value and R^2
stat_cor(label.y = 50, aes(label = paste(..rr.label.., ..p.label.., sep = "~`,`~"))) +
facet_wrap(~ variable, scales = "free", nrow = 1) +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
so4_env <- ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
# Adds the equation (y = mx + b)
stat_regline_equation(label.y = 60, aes(label = ..eq.label..)) +
# Adds the p-value and R^2
stat_cor(label.y = 50, aes(label = paste(..rr.label.., ..p.label.., sep = "~`,`~"))) +
facet_wrap(~ variable, scales = "free", nrow = 1) +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
colnames(so4_cl_data_L2temp)
pairs_data <- so4_cl_data_L2temp %>%
select(SO4_mM, GW_salinity, Soil_EC, Soil_VWC, Soil_Salinity, Water_level)
# , Soil_VWC, Soil_Salinity, Water_level
pairs(pairs_data, pch=19, col='orange', upper.panel=panel.smooth)
ggplot(pairs_data, aes(x = GW_salinity, y = SO4_mM)) +
geom_point(na.rm = TRUE)+
ylim(0, 45)+
geom_smooth(method = "lm")+
theme_classic()
install.packages("GGally")
install.packages("ggplot2")
library(GGally)
library(ggplot2)
ggpairs(pairs_data,
lower = list(continuous = wrap("smooth", method = "lm")), # Add linear regression line to lower panels
upper = list(continuous = wrap("cor", method = "pearson")), # Add correlation coefficients to upper panels
diag = list(continuous = wrap("densityDiag")) # Add density plots to the diagonal
)
pairs_long <- pairs_data %>%
pivot_longer(cols = -SO4_mM, names_to = "variable", values_to = "value")
so4_env <- ggplot(pairs_long, aes(x = value, y = SO4_mM)) +
geom_point() +
geom_smooth(method = "lm") +
# Adds the equation (y = mx + b)
stat_regline_equation(label.y = 60, aes(label = ..eq.label..)) +
# Adds the p-value and R^2
stat_cor(label.y = 50, aes(label = paste(..rr.label.., ..p.label.., sep = "~`,`~"))) +
facet_wrap(~ variable, scales = "free", nrow = 1) +
labs(title = "Sulfate against other variables",
y = "SO4 (mM)",
x = "Value") +
theme_classic()
# Save as a PNG
png("Sulfate versus environmental variables.png", width = 2000, height = 1200, res = 100)
print(so4_env)  # For ggplot objects, use print()
dev.off()
