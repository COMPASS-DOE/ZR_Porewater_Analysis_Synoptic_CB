#   left_join(temps_clean, by=c("Site"="Site", "DateTime_round"="TIMESTAMP_round", "Zone" = "Plot"))
#
# write.csv(so4_cl_data_L2temp, file = "SO4_L2_Data.csv")
#Going to need to use site and timestamp in the metadata in order to find a date
#first we need to make a timestamp column in metadat so that we can
so4_cl_data <- so4_cl_data %>%
mutate(
Time = na_if(Time, ""),
Time = replace_na(Time, "12:00"),
Time = paste0(Time, ":00"))
so4_cl_data$Date <- ifelse(so4_cl_data$Month < 10, paste0(so4_cl_data$Year, "-", "0", so4_cl_data$Month), paste0(so4_cl_data$Year, "-", so4_cl_data$Month))
so4_cl_data$Date_day <- ifelse(so4_cl_data$Day < 10, paste0(so4_cl_data$Date, "0", so4_cl_data$Day), paste0(so4_cl_data$Date, so4_cl_data$Day))
so4_cl_data$TIMESTAMP <- ymd_hms(paste(so4_cl_data$Date_day, so4_cl_data$Time))
#make sure time stamps are in the correct format
so4_cl_data$TIMESTAMP <- as.POSIXct(so4_cl_data$TIMESTAMP, format = "%Y-%m-%d %H:%M:%OS")
#time rounding step
so4_cl_data$DateTime_round <- round_date(so4_cl_data$TIMESTAMP, "15 mins")
##Read in formatted data
so4_cl_data_L2temp <- read.csv("SO4_L2_Data.csv")
data_plotting_so4_cl <- so4_cl_data
head(data_plotting_so4_cl)
data_plotting_so4_cl <- data_plotting_so4_cl %>%
mutate(
Zone_1 = case_when(
Zone == "UP" ~ "Upland",
Zone == "SWAMP" ~ "Swamp",
Zone == "TR" ~ "Transition",
Zone == "WC" ~ "Wetland",
Zone == "SW" ~ "Surface Water",
TRUE ~ Zone  # keep everything else unchanged
)
) %>%
mutate(Zone_1 = factor(Zone_1, levels = c("Upland", "Swamp", "Transition", "Wetland", "Surface Water")))
data_plotting_so4_cl <- data_plotting_so4_cl %>%
mutate(
Site_1 = case_when(
Site == "SWH" ~ "Sweethall",
Site == "GCW" ~ "GCReW",
Site == "MSM" ~ "Moneystump",
Site == "GWI" ~ "Goodwin",
TRUE ~ Site  # keep everything else unchanged
)
) %>%
mutate(Site_1 = factor(Site_1, levels = c("Sweethall", "GCReW", "Moneystump", "Goodwin")))
#Plot samples to get a first look at concentrations (sanity check)
#group the data for plotting
data_plotting_so4_cl <- data_plotting_so4_cl %>%
group_by(Site_1, Zone_1) %>%
mutate(row_num = factor(row_number())) %>%  # create row_num as factor per group
ungroup()
viz_so4_boxplot <- ggplot(data_plotting_so4_cl, aes(x = Zone_1, y = SO4_mM, fill = Zone_1, group = Zone_1)) +
geom_boxplot() +
facet_grid( ~ Site_1, scales = "free_x") +
scale_x_discrete(drop = TRUE) +
scale_fill_manual(values = c(
"Upland" = "#20063B",
"Transition" = "#FFBC42",
"Swamp" = "darkgrey",
"Wetland" = "#419973",
"Surface Water" = "#25ABE6"
), labels = c("Upland", "Swamp", "Transition", "Wetland", "Surface Water")) +
theme_classic() +
labs(x = " ", y = "Sulfate (mM)", title = "Fig 1. Sulfate Across Sites and Zones") +
theme(
panel.spacing = unit(0.5, "lines"),
panel.border = element_rect(color = "black", fill = NA, linewidth = 1)) +
theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1))+
theme(text = element_text(size = 28))+
theme(plot.title = element_text(size = 28)) +
theme(axis.ticks.x = element_line(linewidth = 1))+
theme(axis.ticks.length.x = unit(0.25, "cm"))+
labs(fill = "Zone")
viz_so4_boxplot
# Save as a PNG
png("COMPASS_SynopticCB_SO4_alldata_boxplots.png", width = 1800, height = 700, res = 100)
print(viz_so4_boxplot)  # For ggplot objects, use print()
dev.off()
colnames(so4_cl_data_L2temp)
pairs_data <- so4_cl_data_L2temp %>%
select(SO4_mM, GW_salinity, Soil_EC, Soil_VWC, Water_level, Depth_cm) %>%
rename("Groundwater Salinity" = GW_salinity,
"Soil Electrical Conductivity" = Soil_EC,
"Soil Vol Water Content" = Soil_VWC,
"Groundwater Water Level" = Water_level)
pairs_long <- pairs_data %>%
pivot_longer(cols = -c(SO4_mM, Depth_cm), names_to = "variable", values_to = "value")
pairs_long <- pairs_long %>%
filter(Depth_cm != 0)
pairs_long <- pairs_long %>%
mutate(
Units = case_when(
variable == "Groundwater Salinity" ~ "(meters)",
variable == "Soil Electrical Conductivity" ~ "(μS/cm at 10 cm)",
variable == "Soil Vol Water Content" ~ "(m3/m3 at 10 cm)",
variable == "Groundwater Water Level" ~ "(PSU)",
TRUE ~ variable  # keep everything else unchanged
))
so4_env <- ggplot(pairs_long, aes(x = value, y = SO4_mM, color = as.character(Depth_cm), group = as.character(Depth_cm))) +
geom_point(size = 3) +
geom_smooth(method = "lm", se = FALSE, linewidth = 2) +
facet_wrap(~ variable+Units, scales = "free", nrow = 1, strip.position = "bottom") +
labs(title = "Fig 3. Sulfate versus environmental variables",
y = "Sulfate (mM)",
x = "",
color = "Depth (cm)") +
theme_classic() +
ylim(0, 45)+
theme(text = element_text(size = 28))+
theme(plot.title = element_text(margin = margin(b = 30), size = 28)) +
theme(legend.title = element_text(size = 28),
legend.text = element_text(size = 28)) +
scale_color_manual(values = c(
"10" = "lightblue",
"20" = "blue",
"45" = "darkblue"))+
theme(legend.position = "bottom")+
theme(
strip.background = element_blank(), # Remove the background of the strip
strip.placement = "outside" # Place the strip label outside the axis ticks
) +
theme(legend.box.spacing = unit(-0.75, "cm"), # Space between the plot and the legend box
)
so4_env
# Save as a PNG
png("Sulfate versus environmental variables.png", width = 1800, height = 900, res = 100)
print(so4_env)  # For ggplot objects, use print()
dev.off()
# Plot data and change colors based on Zone:
so4_cl_TR <- data_plotting_so4_cl %>%
filter(str_detect(Zone, "TR")) %>%
filter(str_detect(Depth_cm, "10"))
viz_so4_plot <-  ggplot(so4_cl_TR, aes(x = as.character(Date), y = SO4_mM, fill = Zone)) +
geom_boxplot() +
facet_wrap( ~ Site_1, scales="free") +
scale_fill_manual(values = c(
"UP" = "#20063B",
"TR" = "#FFBC42",
"SWAMP" = "darkgrey",
"WC" = "#419973"
)) +
theme_classic() +
labs(x = " ", y = "Sulfate (mM)", title = "Fig 4. Sulfate in Transitions Zones at 10 cm") +
theme(axis.text.x = element_text(angle = 45, vjust = 1, hjust = 1))+
theme(text = element_text(size = 28))+
theme(axis.title.y = element_text(margin = margin(r = 20), size = 28)) +
theme(legend.position = "none") +
theme(plot.title = element_text(size = 28))
viz_so4_plot
# Save as a PNG
png("Sulfate in Transitions Zones at 20 cm.png", width = 1850, height = 1100, res = 100)
print(viz_so4_plot)  # For ggplot objects, use print()
dev.off()
data_plotting_so4_cl <- data_plotting_so4_cl %>%
filter(Zone != "SW")
##Calculate average and sd
so4_cl_avg <- data_plotting_so4_cl %>%
group_by(Site_1, Zone_1, Depth_cm) %>%
dplyr::summarize(mean_SO4 = mean(SO4_mM, na.rm=TRUE),
sd_SO4 = sd(SO4_mM, na.rm=TRUE))
viz_so4_plot_depth <- ggplot(so4_cl_avg, aes(x = as.numeric(Depth_cm), y = mean_SO4, color = Zone_1, group = Zone_1)) +
geom_point(size = 3) +
geom_errorbar(aes(ymin = mean_SO4 - sd_SO4, ymax = mean_SO4 + sd_SO4), width = 0.5, size = 1) +
geom_line(size = 1.5) +
facet_wrap( ~ Site_1, scales="free", nrow = 1) +
scale_fill_manual(values = c(
"Upland" = "#20063B",
"Transition" = "#FFBC42",
"Swamp" = "darkgrey",
"Wetland" = "#419973",
"Surface Water" = "#25ABE6"
)) +
theme_classic() +
labs(x = "Sampling Depth (cm)", y = "Sulfate (mM)", title = "Fig 2. Sulfate by Depth") +
theme(text = element_text(size = 28)) +
theme(plot.title = element_text(size = 28)) +
coord_flip() +
scale_x_continuous(trans = "reverse") +
labs(color = "Zone")
viz_so4_plot_depth
##Anova
# Model: Sulfate explained by Depth, Site, and Zone, including interactions
# * indicates all main effects and interaction terms
anova_model <- aov(SO4_mM ~ Depth_cm * Site * Zone, data = data_plotting_so4_cl)
# Display results
summary(anova_model)
#check normality
plot(anova_model, 2)
stats <- data_plotting_so4_cl %>%
group_by(Site, Zone) %>%
wilcox_test(SO4_mM ~ Depth_cm) %>% # or anova_test()
add_significance() %>%
add_xy_position(x = "Zone") # Automate p-value positions
# Save as a PNG
png("SO4_by_depth_avgs.png", width = 1800, height = 550, res = 100)
print(viz_so4_plot_depth)  # For ggplot objects, use print()
dev.off()
##Anova
# Model: Sulfate explained by Depth, Site, and Zone, including interactions
# * indicates all main effects and interaction terms
anova_model <- aov(SO4_mM ~ Depth_cm * Site * Zone, data = data_plotting_so4_cl)
# Display results
summary(anova_model)
stats <- data_plotting_so4_cl %>%
group_by(Site, Zone) %>%
wilcox_test(SO4_mM ~ Depth_cm) %>% # or anova_test()
add_significance() %>%
add_xy_position(x = "Zone") # Automate p-value positions
View(stats)
write.csv(stats, "SO4_by_depth_wilcox_stats")
write.csv(stats, "SO4_by_depth_wilcox_stats.csv")
View(stats)
write.csv(stats, file = "SO4_by_depth_wilcox_stats.csv")
write.table(stats, file = "SO4_by_depth_wilcox_stats.csv")
readr::write_csv(stats, file = "SO4_by_depth_wilcox_stats.csv")
View(stats)
#check normality
plot(anova_model, 2)
stats <- data_plotting_so4_cl %>%
group_by(Site, Zone) %>%
wilcox_test(SO4_mM ~ Depth_cm) %>% # or anova_test()
add_significance() %>%
add_xy_position(x = "Zone") # Automate p-value positions
stats <- data_plotting_so4_cl %>%
group_by(Site, Zone) %>%
wilcox_test(SO4_mM ~ Depth_cm) %>% # or anova_test()
add_significance() %>%
add_xy_position(x = "Zone") # Automate p-value positions
readr::write_csv(stats, file = "SO4_by_depth_wilcox_stats.csv")
stats_clean <- stats %>%
mutate(groups = map_chr(groups, ~ paste0('c("', paste(.x, collapse = '", "'), '")')))
