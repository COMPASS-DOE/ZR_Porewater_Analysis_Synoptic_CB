results <- data_plotting_so4_cl %>%
group_by(Site) %>%
do({
model = aov(so4_dep ~ Zone, data = .)
tukey = TukeyHSD(model)
cld = multcompLetters4(model, tukey)
# Extract letters and turn into a data frame
data.frame(
Zone = names(cld$Zone$Letters),
Letters = cld$Zone$Letters
)
})
