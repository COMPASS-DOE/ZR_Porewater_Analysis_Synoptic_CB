stat_summary(fun = mean, geom = "bar", position = "dodge") +
stat_summary(fun.data = mean_sd, geom = "errorbar", width = 0.2) +
facet_wrap(~Site) +
theme_minimal() +
stat_pvalue_manual(stats, label = "p.adj.signif", tip.length = 0.01, inherit.aes = FALSE)
